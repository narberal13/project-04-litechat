# ============================================================
# SiteScan + ToSWatch — 環境変数一括設定ファイル
# このファイルを .env にコピーして値を埋めてください
# cp .env.example .env
# ============================================================

# --- Claude API ---
# https://console.anthropic.com/settings/keys で発行
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Stripe（決済）---
# https://dashboard.stripe.com/apikeys で取得
# オンボーディング未完了の場合でも設定可能（決済は保留される）
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_SINGLE=price_xxxxx
STRIPE_PRICE_MONTHLY=price_xxxxx

# --- Resend（メール通知）---
# https://resend.com/api-keys で発行
# ドメイン認証: https://resend.com/domains でpik-tal.comを追加
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=noreply@pik-tal.com

# --- Discord（管理者通知）---
# サーバー > チャンネル設定 > 連携サービス > Webhook > URLをコピー
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/xxxxx

# --- PayPal（Stripe代替決済・後日対応）---
# https://developer.paypal.com/dashboard/ で取得
# PAYPAL_CLIENT_ID=xxxxx
# PAYPAL_CLIENT_SECRET=xxxxx

# --- アプリ設定 ---
APP_URL=https://pik-tal.com
API_URL=https://api.pik-tal.com
DATABASE_URL=sqlite:///./sitescan.db

# --- レート制限 ---
MAX_FREE_SCANS_PER_MONTH=3
MAX_CONCURRENT_SCANS=2
API_MONTHLY_BUDGET_USD=50
