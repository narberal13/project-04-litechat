# --- LLM (llama.cpp server) ---
LLAMA_SERVER_URL=http://127.0.0.1:8080

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_LITE=price_xxxxx
STRIPE_PRICE_PLUS=price_xxxxx

# --- Discord（管理者通知）---
